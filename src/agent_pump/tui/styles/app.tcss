/* Agent Pump TUI Styles */

/* Semantic Variables (Dark Theme Default) */
$success: #2ecc71;
$warning: #f1c40f;
$error: #e74c3c;
$info: #3498db;
$primary: #9b59b6;
$secondary: #8e44ad;
$accent: #e67e22;
$text-muted: #7f8c8d;
$surface: #2c3e50;
$surface-lighten-1: #3a4f64;
$surface-lighten-2: #496077;
$background: #1a252f;
$glass-background: rgba(26, 37, 47, 0.8);
$primary-background: #1a252f;
$primary-darken-2: #8e44ad;

/* New Semantic Variables */
$text-inverse: #ffffff;
$text-on-error: #ffffff;
$text-main-light: #000000;
$primary-muted: $surface-lighten-2;
$glass-surface: rgba(44, 62, 80, 0.95);

/* Light Theme Variables */
$surface-light: #ecf0f1;
$surface-accent-1-light: #bdc3c7;
$surface-accent-2-light: #95a5a6;
$background-light: #ffffff;
$glass-background-light: rgba(255, 255, 255, 0.8);
$primary-background-light: #ffffff;
$text-muted-light: #7f8c8d;
$glass-surface-light: rgba(236, 240, 241, 0.95);

/* Status Classes */
.status-idle { color: $text-muted; }
.status-planning { color: $warning; }
.status-implementing { color: $info; }
.status-brainstorming { color: $accent; }
.status-committing { color: $success; }
.status-paused { color: $text-muted; }
.status-error { color: $error; }
.status-completed { color: $success; text-style: bold; }

/* Main Layout */
#app-container {
    height: 100%;
    width: 100%;
}

#main-layout {
    height: 100%;
    width: 100%;
}

/* Sidebar */
#sidebar {
    width: 40;
    min-width: 30;
    max-width: 50;
    height: 100%;
    background: $surface;
    border-right: solid $primary-background;
    padding: 1;
}

.light #sidebar {
    background: $surface-light;
    border-right: solid $primary-background-light;
}

/* Project List */
#project-list {
    height: 1fr;
    overflow-y: auto;
    padding: 0 1;
}

.light #project-list {
    background: $surface-light;
}

/* Button Row */
.button-row {
    height: auto;
    padding: 1;
    dock: bottom;
}

.button-row Button {
    margin: 0 1;
}

/* Main Content */
#main-content {
    height: 100%;
    padding: 1;
}

/* Section Titles */
.section-title {
    text-style: bold;
    color: $primary;
    padding: 1 2;
    background: $surface;
}

.light .section-title {
    background: $surface-light;
}

/* Log Panel */
#log-panel {
    height: 1fr;
    background: $background;
    border: solid $primary-background;
}

.light #log-panel {
    background: $background-light;
    border: solid $primary-background-light;
}

/* General */
Screen {
    background: $background;
    layers: base above;
}

.light {
    background: $background-light;
    color: $text-main-light;
}

Header {
    background: $primary;
}

#right-sidebar {
    width: 80;
    min-width: 70;
    max-width: 100;
    height: 100%;
    background: $surface;
    border-left: solid $primary-background;
    padding: 1;
}

.light #right-sidebar {
    background: $surface-light;
    border-left: solid $primary-background-light;
}

Footer {
    background: $surface;
}

.light Footer {
    background: $surface-light;
}

#quit-button {
    background: $error;
    color: $text-on-error;
    text-style: bold;
    padding: 0 1;
    width: 11;
    height: 1;
    position: absolute;
    offset: 100% 0;
    margin-left: -11;
    layer: above;
}

#quit-indicator {
    background: $error;
    color: $text-on-error;
    text-style: bold;
    padding: 0 1;
    width: auto;
    height: 1;
}

/* Widget Overrides for Light Theme */
.light ProjectCard {
    background: $surface-light;
    border: solid $primary-background-light;
}

.light ProjectCard.selected {
    background: $surface-accent-1-light;
}

.light #workflow-panel {
    background: $surface-light;
}

.light WorkflowNode {
    background: $surface-light;
    border: solid $surface-accent-2-light;
}

.light WorkflowNode:hover {
    background: $surface-accent-1-light;
}

.light WorkflowNode.active {
    background: $surface-accent-1-light;
}
