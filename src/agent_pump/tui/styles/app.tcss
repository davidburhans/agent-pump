/* Agent Pump TUI Styles */

/* Main Layout */
#app-container {
    height: 100%;
    width: 100%;
}

#main-layout {
    height: 100%;
    width: 100%;
}

/* Sidebar */
#sidebar {
    width: 40;
    min-width: 30;
    max-width: 50;
    height: 100%;
    background: $surface;
    border-right: solid $primary-background;
    padding: 1;
}

/* Project List */
#project-list {
    height: 1fr;
    overflow-y: auto;
    padding: 0 1;
}

/* Button Row */
.button-row {
    height: auto;
    padding: 1;
    dock: bottom;
}

.button-row Button {
    margin: 0 1;
}

/* Main Content */
#main-content {
    height: 100%;
    padding: 1;
}

/* Section Titles */
.section-title {
    text-style: bold;
    color: $primary;
    padding: 1 2;
    background: $surface;
}

/* Log Panel */
#log-panel {
    height: 1fr;
    background: $background;
    border: solid $primary-background;
}

/* General */
Screen {
    background: $background;
    layers: base above;
}

Header {
    background: $primary;
}

#right-sidebar {
    width: 80;
    min-width: 70;
    max-width: 100;
    height: 100%;
    background: $surface;
    border-left: solid $primary-background;
    padding: 1;
}

Footer {
    background: $surface;
}

#quit-button {
    background: $error;
    color: white;
    text-style: bold;
    padding: 0 1;
    width: 11;
    height: 1;
    position: absolute;
    offset: 100% 0;
    margin-left: -11;
    layer: above;
}

#quit-indicator {
    background: $error;
    color: white;
    text-style: bold;
    padding: 0 1;
    width: auto;
    height: 1;
}
